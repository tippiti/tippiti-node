{
  "name": "@tippiti/api-client",
  "version": "1.0.4",
  "description": "Official TypeScript client for the Tippiti API – the transcription and dictation platform for physicians, attorneys, forensic examiners and professional typing services.",
  "keywords": [
    "tippiti",
    "transcription",
    "dictation",
    "medical-transcription",
    "legal-transcription",
    "openapi",
    "api-client",
    "typescript"
  ],
  "homepage": "https://tippiti.io",
  "bugs": {
    "url": "https://github.com/tippiti/tippiti-node/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tippiti/tippiti-node.git"
  },
  "license": "MIT",
  "author": "Tippiti <support@tippiti.io> (https://tippiti.io)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "openapi-typescript https://apidocs.tippiti.io/api.json -o src/generated.ts",
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
